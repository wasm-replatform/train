export enum Status { Pending = 0, Active = 1, Disabled = 2 }

export function normalizeUser(raw: { name: string; status: number }) {
  const trimmed = raw.name.trim();
  let state: Status;
  switch (raw.status) {
    case 0: state = Status.Pending; break;
    case 1: state = Status.Active; break;
    case 2: state = Status.Disabled; break;
    default: throw new Error("unknown status");
  }
  return { name: trimmed, status: state };
}
